APP_ENV=development
LOG_LEVEL=INFO
PREFER_DOTENV_IN_DEV=1
LLM_ROUTER=0
LLM_ROUTER_MODEL=gpt-4.1-mini
LLM_ROUTER_THRESHOLD=0.7
LLM_ROUTER_RETRIES=1
UNKNOWN_LLM_REPLY=0
UNKNOWN_LLM_MODEL=gpt-5-mini
LLM_TIMEWINDOW=0
LLM_TIMEWINDOW_MODEL=gpt-5-mini
LLM_TIMEWINDOW_THRESHOLD=0.75
LLM_CALENDAR_CREATE_TIME=0
LLM_CALENDAR_CREATE_MODEL=gpt-5-mini
LLM_CALENDAR_CREATE_THRESHOLD=0.75
DEFAULT_TIMEZONE=America/New_York
# TIMEWINDOW_NOW_ISO=2026-02-18T09:30:00-05:00
OPENAI_API_KEY=
OPENAI_INPUT_COST_PER_1K_USD=0
OPENAI_OUTPUT_COST_PER_1K_USD=0
PROMPT_VERSION=v1
DATABASE_URL=
# M2 calendar config
MOCK_CALENDAR=1
GOOGLE_CALENDAR_MODE=mock
GOOGLE_CALENDAR_ID=primary
CALENDAR_FIXTURE_PATH=tests/fixtures/sample_calendar.json
# Optional for oauth mode
# GOOGLE_OAUTH_CLIENT_SECRET_JSON=path/to/client_secret.json
# GOOGLE_OAUTH_TOKEN_JSON=path/to/token.json
# M3 weather + commute config
MOCK_WEATHER=1
WEATHER_MODE=mock
WEATHER_FIXTURE_PATH=tests/fixtures/sample_weather.json
WEATHER_LATITUDE=39.9526
WEATHER_LONGITUDE=-75.1652
WEATHER_FORECAST_HOURS=6
MOCK_ETA=1
ETA_MODE=mock
ETA_PROVIDER=mock
ETA_FIXTURE_PATH=tests/fixtures/sample_eta.json
ETA_BASE_MINUTES=30
ETA_CACHE_TTL_SECONDS=90
DEFAULT_ORIGIN=Home
# GOOGLE_ROUTES_API_KEY=
# ROUTES_API=
# M4 todo automation
TODOIST_API_TOKEN=
TODO_PARSER_MODEL=gpt-5-mini
TODO_CONFIDENCE_THRESHOLD=0.7
TODO_PARSE_RETRIES=2
# M5 leaving checklist
CHECKLIST_MODEL=gpt-5-mini
CHECKLIST_CONFIDENCE_THRESHOLD=0.7
CHECKLIST_RETRIES=2
# Optional deterministic testing override
# COMMUTE_NOW_ISO=2026-01-15T08:10:00+00:00
